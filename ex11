#Conversion factor from miles per gallon to liters per 100 kilometers
conv = 235.215
#User Input in miles per gallon
mpg = float(input("Enter miles per gallon: "))
#Calculating liters per 100 kilometers
l100 = conv / mpg
#Output
print (f"\n{mpg} miles per gallon is equivalent to {l100:.2f} liters per 100 kilometers.")