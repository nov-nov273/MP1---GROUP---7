import math

#User Input
A = int(input("Enter the first integer: "))
B = int(input("Enter the second integer: "))

print (f"\nThe sum of {A} and {B} is: {A + B}")
print (f"The difference when {B} is subtracted from {A} is: {A - B}")
print (f"The product of {A} and {B} is: {A * B}")
print (f"The quotient when {A} is divided by {B} is: {A / B:.2f}")
print (f"The result of log base 10 of {A} is: {math.log10(A):.2f}")
print (f"The result of a^b is: {A ** B}")