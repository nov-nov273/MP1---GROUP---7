#Variables
Tax = 0.12
Tip = 0.18
Meal_Cost = float(input("Enter the cost of the meal: "))
#Calculations
Tax_Amount = Meal_Cost * Tax
Tip_Amount = Meal_Cost * Tip
Total_Cost = Meal_Cost + Tax_Amount + Tip_Amount
#Output
print (f"\nTax Amount (12%): {Tax_Amount:.2f}")
print (f"Tip Amount (18%): {Tip_Amount:.2f}")
print (f"Total Cost: {Total_Cost:.2f}")